#compdef gtd
#
# zsh completion for the `gtd` command.
#
# IMPORTANT — alias vs function:
#   If `gtd` is an *alias*, zsh expands it before completing, so this file is
#   ignored unless you also `setopt complete_aliases`. The robust fix is to
#   define `gtd` as a FUNCTION instead, which completes as `gtd` directly:
#       gtd() { python3 /path/to/gtd.py "$@" }
#   (Under oh-my-zsh, put that in ~/.zshrc; remove any `alias gtd=...`.)
#
# INSTALL (oh-my-zsh)
#   1. Save this file as `_gtd` in oh-my-zsh's custom completions dir:
#          mkdir -p ~/.oh-my-zsh/custom/completions
#          cp _gtd ~/.oh-my-zsh/custom/completions/_gtd
#   2. Clear the completion cache and restart the shell:
#          rm -f ~/.zcompdump* && exec zsh
#
# INSTALL (plain zsh, no framework)
#   1. Put this file as `_gtd` in a dir on $fpath, e.g. ~/.zsh/completions/_gtd
#   2. In ~/.zshrc, BEFORE compinit runs:
#          fpath=(~/.zsh/completions $fpath)
#          autoload -Uz compinit && compinit
#
# After install, `gtd me<TAB>` completes to `gtd metadata`, and arguments
# (subcommands, .eml filenames, field names, destinations) complete too.
# Verify it loaded:  print ${_comps[gtd]}   # should print: _gtd

# Locate config.yml so we can offer real .eml filenames. We look next to the
# gtd.py that the alias points at; fall back to the current directory.
_gtd_working_directory() {
    local script_dir cfg wd
    # Extract the gtd.py path from the alias definition, if present.
    # Find the gtd.py path the `gtd` command points at. Works whether `gtd` is
    # a shell function (recommended) or an alias, and falls back to $PWD.
    local py_path="" tok
    if (( $+functions[gtd] )); then
        # Scan the function body for the token ending in gtd.py.
        for tok in ${(z)functions[gtd]}; do
            if [[ "$tok" == *gtd.py ]]; then
                py_path="$tok"
                break
            fi
        done
    fi
    if [[ -z "$py_path" && -n "${aliases[gtd]}" ]]; then
        for tok in ${(z)${aliases[gtd]}}; do
            [[ "$tok" == *gtd.py ]] && py_path="$tok" && break
        done
        # Fall back to the last word if no *gtd.py token was found.
        [[ -z "$py_path" ]] && py_path="${${(z)${aliases[gtd]}}[-1]}"
    fi

    if [[ -n "$py_path" && -f "$py_path" ]]; then
        script_dir="${py_path:h}"
    else
        script_dir="$PWD"
    fi
    cfg="$script_dir/config.yml"

    if [[ -f "$cfg" ]]; then
        # Pull `working_directory:` from the YAML, strip quotes/whitespace.
        wd=$(sed -n 's/^[[:space:]]*working_directory:[[:space:]]*//p' "$cfg" \
                 | head -1 | sed 's/^["'\'']//; s/["'\''][[:space:]]*$//')
    fi
    [[ -z "$wd" ]] && wd="$script_dir/gtd-eml"
    print -r -- "$wd"
}

# Collect .eml filenames across all workflow folders.
_gtd_eml_files() {
    local wd; wd="$(_gtd_working_directory)"
    local -a files
    files=("${(@f)$(find "$wd" -mindepth 2 -maxdepth 2 -name '*.eml' \
                        -exec basename {} \; 2>/dev/null)}")
    compadd -a files
}

_gtd() {
    local -a subcommands
    subcommands=(
        'list:Print the status report (optionally one folder)'
        'stats:Show how many emails are in each folder'
        'view:Preview a single email'
        'alloc:Move an email to another folder'
        'close:Archive an email and record what closed it'
        'pin:Add the "pinned" flag to an email'
        'unpin:Remove the "pinned" flag from an email'
        'metadata:Get or set a metadata.csv field'
        'help:Show the command overview'
    )

    local -a destinations fields
    # Folder aliases accepted by `alloc` and `list` (mirror FOLDERS_BY_ALIAS).
    destinations=(actionable delegated reference archive triage input)
    fields=(general_notes project next_action flags message_ref)

    # $words excludes the command word offset by $CURRENT; position 1 is the
    # subcommand, 2+ are its arguments.
    if (( CURRENT == 2 )); then
        _describe -t commands 'gtd command' subcommands
        return
    fi

    local cmd="${words[2]}"
    case "$cmd" in
        list)
            # Optional single folder to show just that segment.
            (( CURRENT == 3 )) && _describe -t folders 'folder' destinations
            ;;
        view)
            (( CURRENT == 3 )) && _gtd_eml_files
            ;;
        alloc)
            if (( CURRENT == 3 )); then
                _gtd_eml_files
            elif (( CURRENT == 4 )); then
                _describe -t destinations 'destination' destinations
            fi
            ;;
        close)
            if (( CURRENT == 3 )); then
                _gtd_eml_files
            elif (( CURRENT == 4 )); then
                # The literal word "with" is optional; offer it plus filenames.
                compadd with
                _gtd_eml_files
            elif (( CURRENT == 5 )); then
                _gtd_eml_files
            fi
            ;;
        pin|unpin)
            (( CURRENT == 3 )) && _gtd_eml_files
            ;;
        metadata)
            if (( CURRENT == 3 )); then
                _gtd_eml_files
            elif (( CURRENT == 4 )); then
                _values 'action' get set
            elif (( CURRENT == 5 )); then
                _describe -t fields 'field' fields
            fi
            ;;
    esac
}

_gtd "$@"
